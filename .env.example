# Credenciales de la API de Google Analytics 4 (GA4 Data API)
# Copia este fichero a .env y rellena los 4 valores (Pilar te los pasa por DM).
# El fichero .env está en .gitignore: NUNCA se sube al repositorio.

# ID numérico de la propiedad GA4 (Admin → Configuración de la propiedad)
GA4_PROPERTY_ID=123456789

# ID del proyecto de Google Cloud de la cuenta de servicio
GA4_PROJECT_ID=mi-proyecto-gcp

# Email de la cuenta de servicio (xxx@mi-proyecto.iam.gserviceaccount.com)
GA4_CLIENT_EMAIL=cuenta-servicio@mi-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio. Pégala entre comillas y con los
# saltos de línea escapados como \n (formato del JSON de la cuenta de servicio).
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
